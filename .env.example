# Copy this file to .env and fill in real values. .env is gitignored so
# credentials never end up in version control or commit history.

PERLITE_USERNAME=admin

# Generate with (the sed doubles every '$' - required because docker-compose
# treats a single '$' in .env as variable interpolation and will silently
# mangle the hash otherwise; quoting the value does NOT prevent this):
#   docker run --rm perlite-auth-app php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT), PHP_EOL;" | sed 's/\$/$$/g'
# Default below is bcrypt('admin') - change it before exposing the app.
PERLITE_PASSWORD_HASH=$$2y$$10$$IJuy5jLFSy6L3OChjmL3euBMLuCMCx17C3h7bNIeuk4hftuH.LUXK
